    "review::.::holistic::type_safety::validate_interfaces_optionality_mismatch": {
      "id": "review::.::holistic::type_safety::validate_interfaces_optionality_mismatch",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "lib/validate.ts validator input interfaces declare required fields as optional, undermining TypeScript enforcement on pre-write guards",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "lib/validate.ts",
          "app/api/scrape/route.ts",
          "app/api/vote/route.ts",
          "app/api/restaurant-vote/route.ts"
        ],
        "evidence": [
          "interface RestaurantInput { name?: string | null; city?: string | null; status?: string | null; upvotes?: number | null; downvotes?: number | null; ... } \u2014 all optional",
          "validateRestaurantInput enforces name, city, status, upvotes, downvotes as required via requireString/requirePresent \u2014 but TypeScript does not enforce this",
          "A caller can pass validateRestaurantInput({}) and TypeScript will compile without error, only failing at runtime",
          "Same mismatch in 7 other interfaces: ParsedQuery, RedditPost, ExtractedRestaurant, PlaceDetails, CommunityRecommendationInput, RestaurantVoteInput, VoteInput"
        ],
        "suggestion": "For fields that validateX enforces as required, remove the '?' optional marker and remove '| null' from the type where null is not a valid value. Fields that are genuinely optional in the data model should remain optional.",
        "reasoning": "",
        "summary_hash": "62cddb7d"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-04-02T14:46:28+00:00",
