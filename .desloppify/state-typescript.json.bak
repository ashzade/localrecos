    "review::.::holistic::type_safety::vote_routes_enum_bypass": {
      "id": "review::.::holistic::type_safety::vote_routes_enum_bypass",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "Both vote route handlers use raw string comparison against 'up'/'down' instead of VoteDirection enum, bypassing available type safety",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "app/api/vote/route.ts",
          "app/api/restaurant-vote/route.ts"
        ],
        "evidence": [
          "app/api/vote/route.ts lines 27-29: `if (direction !== 'up' && direction !== 'down')` \u2014 magic string validation",
          "Line 56: `const voteDirection = direction === 'up' ? VoteDirection.up : VoteDirection.down;` \u2014 mapping done manually",
          "VoteDirection is imported from @prisma/client (line 5) but used only at the Prisma call site",
          "app/api/restaurant-vote/route.ts lines 27-29, 56: identical pattern",
          "TypeScript cannot narrow direction's type from string to 'up' | 'down' without an explicit Literal type, so subsequent code treats it as string"
        ],
        "suggestion": "Add a type guard: `function isVoteDirection(d: string): d is 'up' | 'down' { return d === 'up' || d === 'down'; }` and use it for the validation check. Then `direction` is narrowed to `'up' | 'down'` in the success path, and the ternary mapping becomes type-safe.",
        "reasoning": "",
        "summary_hash": "842ad7fd"
      },
      "status": "fixed",
      "note": "not reported in latest holistic re-import",
