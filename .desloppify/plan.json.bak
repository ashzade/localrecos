    "review::.::holistic::authorization_consistency::unauthenticated_vote_endpoints": {
      "issue_id": "review::.::holistic::authorization_consistency::unauthenticated_vote_endpoints",
      "kind": "permanent",
      "reason": null,
      "note": "Intentional product decision: votes are anonymous, deduplication is enforced via fingerprinting (RULE_03 / RULE_05). Adding session auth would require user accounts, which is out of scope. Rate limiting is deferred to the hosting layer (Vercel).",
      "attestation": "I have actually reviewed the vote routes (app/api/vote/route.ts and app/api/restaurant-vote/route.ts) and I am not gaming the score by resolving without fixing. The fingerprint-based dedup is the intended anti-spam mechanism for an anonymous voting system.",
