# Database
# For Neon: DATABASE_URL uses the pooler connection string, DIRECT_URL uses the direct connection
DATABASE_URL="postgresql://user:password@localhost:5432/localrecos"
DIRECT_URL="postgresql://user:password@localhost:5432/localrecos"

# Foursquare Places API (optional - gracefully degraded if missing)
# Get a key at https://foursquare.com/developers/
FOURSQUARE_API_KEY="your_foursquare_api_key_here"

# Reddit User Agent (customize with your app name)
REDDIT_USER_AGENT="LocalRecos/1.0"
