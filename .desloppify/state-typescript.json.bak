    "review::.::holistic::type_safety::parallel_parsedquery_interface_definitions": {
      "id": "review::.::holistic::type_safety::parallel_parsedquery_interface_definitions",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "low",
      "summary": "ParsedQuery is defined twice with diverging shapes: lib/search.ts has required city/terms/raw, lib/validate.ts has all fields optional",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "lib/search.ts",
          "lib/validate.ts"
        ],
        "evidence": [
          "lib/search.ts lines 8-12: `export interface ParsedQuery { city: string | null; terms: string; raw: string; }`",
          "lib/validate.ts lines 18-22: `interface ParsedQuery { city?: string | null; terms?: string | null; raw?: string | null; }`",
          "The validate.ts version intentionally uses optional fields to avoid circular imports (documented in the file header), but the two interfaces diverge: validate.ts ParsedQuery allows all fields to be missing, while search.ts ParsedQuery requires terms and raw",
          "A function accepting validate.ts's ParsedQuery cannot be safely passed a search.ts ParsedQuery without widening"
        ],
        "suggestion": "The lib/validate.ts approach (optional fields for circular import avoidance) is documented and intentional. No change needed to the interface shapes, but add a comment in lib/search.ts's ParsedQuery: `// Canonical shape; lib/validate.ts uses a structurally similar optional interface for circular-import safety`. This documents why two interfaces exist.",
        "reasoning": "",
        "summary_hash": "36d04c4c"
      },
      "status": "fixed",
      "note": "not reported in latest holistic re-import",
