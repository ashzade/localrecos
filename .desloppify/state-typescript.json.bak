    "review::.::holistic::contract_coherence::validate_interfaces_weaker_than_runtime": {
      "id": "review::.::holistic::contract_coherence::validate_interfaces_weaker_than_runtime",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "lib/validate.ts interfaces declare all fields as optional but validators throw if fields are absent \u2014 TypeScript type is weaker than the runtime contract",
      "detail": {
        "holistic": true,
        "dimension": "contract_coherence",
        "related_files": [
          "lib/validate.ts"
        ],
        "evidence": [
          "interface RestaurantInput { name?: string | null; city?: string | null; ... } \u2014 all fields optional",
          "validateRestaurantInput calls requireString(o, 'name', 'Restaurant') which throws if name is null/undefined/empty",
          "Caller can pass {} without TypeScript error, but runtime throws ValidationError",
          "Same pattern across all 8 validator functions and their interfaces"
        ],
        "suggestion": "For fields that validateX enforces as required, remove the '?' optional marker and remove '| null' where null is invalid. Fields that are genuinely optional in the domain should remain optional. This aligns the TypeScript type with the runtime enforcement.",
        "reasoning": "",
        "summary_hash": "1d19d094"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-04-02T14:46:28+00:00",
      "last_seen": "2026-04-02T14:46:28+00:00",
