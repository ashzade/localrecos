    "review::.::holistic::initialization_coupling::reddit_mutable_module_singleton": {
      "id": "review::.::holistic::initialization_coupling::reddit_mutable_module_singleton",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "Mutable OAuth token cache is module-level singleton, leaks across requests in serverless",
      "detail": {
        "holistic": true,
        "dimension": "initialization_coupling",
        "related_files": [
          "lib/reddit.ts"
        ],
        "evidence": [
          "Line 58: `let cachedToken: { token: string; expiresAt: number } | null = null`",
          "In Next.js serverless (Vercel), each function invocation may reuse the module instance across requests, meaning one user's token refresh can affect another's timing window.",
          "`getAccessToken()` reads and writes this singleton without any lock, creating a potential race condition under concurrent requests."
        ],
        "suggestion": "The current caching is acceptable in a long-running server context. For serverless, consider moving token caching to an external store (Redis/KV) or accepting that each cold start re-fetches. At minimum, document that this module assumes single-process execution.",
        "reasoning": "",
        "summary_hash": "a1647b60"
      },
