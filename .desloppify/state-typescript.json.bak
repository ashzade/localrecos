    "review::.::holistic::type_safety::status_enum_bypass": {
      "id": "review::.::holistic::type_safety::status_enum_bypass",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "RestaurantStatus Prisma enum bypassed with raw string literals in component status lookups",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "components/RestaurantCard.tsx",
          "components/TrendingSection.tsx",
          "app/restaurant/[id]/page.tsx"
        ],
        "evidence": [
          "RestaurantCard.tsx line 40: `status: string` in the Restaurant interface instead of `RestaurantStatus`.",
          "RestaurantCard.tsx line 51: `const STATUS_LABELS: Record<string, {...}>` \u2014 string keys 'VERIFIED', 'UNREVIEWED', 'INCOMPLETE'. The type system cannot catch if a new status is added to the Prisma enum.",
          "TrendingSection.tsx line 6: `status: string` in TrendingRestaurant interface.",
          "app/restaurant/[id]/page.tsx line 13: `const STATUS_INFO: Record<string, {...}>` with string keys.",
          "If the Prisma enum adds or renames a status value, TypeScript will not flag the outdated component lookups."
        ],
        "suggestion": "Import RestaurantStatus from '@prisma/client' in the component interfaces and Record types. Change `status: string` to `status: RestaurantStatus` and `Record<string, {...}>` to `Record<RestaurantStatus, {...}>`. The type system will then flag exhaustiveness gaps when the enum changes.",
        "reasoning": "",
        "summary_hash": "fb19fcb0"
      },
      "status": "fixed",
      "note": "not reported in latest holistic re-import",
