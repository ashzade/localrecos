{
  "meta": {
    "featureId": "restaurant_recommendations",
    "version": "1.0.0",
    "status": "draft",
    "owner": "platform-team",
    "dependsOn": [
      "foursquare_api",
      "google_places_api",
      "reddit_api"
    ],
    "tags": [
      "recommendations",
      "restaurants",
      "search"
    ]
  },
  "feature": {
    "name": "Restaurant Recommendations",
    "intent": "Accepts natural-language queries, fetches Reddit community discussions, extracts restaurant mentions, enriches them with place details from Foursquare and Google Places, and returns ranked recommendations."
  },
  "externalProviders": {
    "FoursquareAPI": {
      "methods": [
        {
          "name": "search",
          "params": [
            {
              "name": "name",
              "type": "string"
            },
            {
              "name": "city",
              "type": "string"
            }
          ],
          "returns": "json"
        },
        {
          "name": "getDetails",
          "params": [
            {
              "name": "venue_id",
              "type": "string"
            }
          ],
          "returns": "json"
        }
      ],
      "source": "foursquare-api",
      "provides": "venue details and ratings for restaurants",
      "lookupKey": "place_name"
    },
    "GooglePlacesAPI": {
      "methods": [
        {
          "name": "findPlace",
          "params": [
            {
              "name": "name",
              "type": "string"
            },
            {
              "name": "city",
              "type": "string"
            }
          ],
          "returns": "json"
        },
        {
          "name": "getDetails",
          "params": [
            {
              "name": "place_id",
              "type": "string"
            }
          ],
          "returns": "json"
        }
      ],
      "source": "google-places-api",
      "provides": "place details, hours, and photos for restaurants",
      "lookupKey": "place_id"
    },
    "RedditAPI": {
      "methods": [
        {
          "name": "search",
          "params": [
            {
              "name": "query",
              "type": "string"
            },
            {
              "name": "subreddit",
              "type": "string"
            }
          ],
          "returns": "json"
        },
        {
          "name": "getPost",
          "params": [
            {
              "name": "post_id",
              "type": "string"
            }
          ],
          "returns": "json"
        }
      ],
      "source": "reddit-api",
      "provides": "community posts and comments mentioning restaurants",
      "lookupKey": "query"
    }
  },
  "stateMachine": {
    "states": {
      "PENDING": "query received, Reddit fetch not yet attempted",
      "FETCHING": "Reddit posts are being retrieved and parsed",
      "EXTRACTING": "restaurant names are being extracted from posts",
      "ENRICHING": "place details are being fetched from external APIs",
      "COMPLETE": "all enrichment succeeded and recommendations are ready",
      "FAILED": "one or more unrecoverable errors occurred during processing"
    },
    "transitions": [
      {
        "from": "PENDING",
        "to": "FETCHING",
        "actions": [
          {
            "type": "emit_event",
            "args": [
              "QUERY_RECEIVED"
            ]
          },
          {
            "type": "set_field",
            "args": [
              "entity.status",
              "'fetching'"
            ]
          }
        ],
        "trigger": "query submitted by user",
        "guard": "RULE_01"
      },
      {
        "from": "FETCHING",
        "to": "EXTRACTING",
        "actions": [
          {
            "type": "emit_event",
            "args": [
              "POSTS_FETCHED"
            ]
          },
          {
            "type": "set_field",
            "args": [
              "entity.status",
              "'extracting'"
            ]
          }
        ],
        "trigger": "Reddit posts retrieved successfully",
        "guard": "RULE_02"
      },
      {
        "from": "FETCHING",
        "to": "FAILED",
        "actions": [
          {
            "type": "emit_event",
            "args": [
              "FETCH_FAILED"
            ]
          },
          {
            "type": "set_field",
            "args": [
              "entity.status",
              "'failed'"
            ]
          }
        ],
        "trigger": "Reddit fetch raises an exception"
      },
      {
        "from": "EXTRACTING",
        "to": "ENRICHING",
        "actions": [
          {
            "type": "emit_event",
            "args": [
              "EXTRACTION_COMPLETE"
            ]
          },
          {
            "type": "set_field",
            "args": [
              "entity.status",
              "'enriching'"
            ]
          }
        ],
        "trigger": "restaurant names extracted from posts",
        "guard": "RULE_03"
      },
      {
        "from": "EXTRACTING",
        "to": "FAILED",
        "actions": [
          {
            "type": "emit_event",
            "args": [
              "EXTRACTION_FAILED"
            ]
          },
          {
            "type": "set_field",
            "args": [
              "entity.status",
              "'failed'"
            ]
          }
        ],
        "trigger": "extraction yields no results"
      },
      {
        "from": "ENRICHING",
        "to": "COMPLETE",
        "actions": [
          {
            "type": "emit_event",
            "args": [
              "ENRICHMENT_COMPLETE"
            ]
          },
          {
            "type": "set_field",
            "args": [
              "entity.status",
              "'complete'"
            ]
          }
        ],
        "trigger": "place details fetched for all extracted restaurants"
      },
      {
        "from": "ENRICHING",
        "to": "FAILED",
        "actions": [
          {
            "type": "emit_event",
            "args": [
              "ENRICHMENT_FAILED"
            ]
          },
          {
            "type": "set_field",
            "args": [
              "entity.status",
              "'failed'"
            ]
          }
        ],
        "trigger": "enrichment raises an unrecoverable exception"
      },
      {
        "from": "FAILED",
        "to": "PENDING",
        "actions": [
          {
            "type": "set_field",
            "args": [
              "entity.status",
              "'pending'"
            ]
          }
        ],
        "trigger": "retry requested by user"
      }
    ]
  },
  "actors": {
    "SystemPipeline": {
      "read": [
        "parsed_queries",
        "reddit_posts",
        "extracted_restaurants",
        "place_details",
        "place_details_raw"
      ],
      "write": [
        "parsed_queries",
        "reddit_posts",
        "extracted_restaurants",
        "place_details",
        "place_details_raw",
        "restaurants_with_recommendations"
      ]
    },
    "PublicAPI": {
      "read": [
        "restaurants_with_recommendations",
        "parsed_queries"
      ],
      "write": [
        "parsed_queries"
      ]
    }
  },
  "enforcement": [
    {
      "ruleId": "RULE_01",
      "severity": "HIGH",
      "responses": [
        {
          "action": "reject"
        }
      ]
    },
    {
      "ruleId": "RULE_02",
      "severity": "MEDIUM",
      "responses": [
        {
          "action": "reject"
        }
      ]
    },
    {
      "ruleId": "RULE_03",
      "severity": "MEDIUM",
      "responses": [
        {
          "action": "reject"
        }
      ]
    },
    {
      "ruleId": "RULE_04",
      "severity": "LOW",
      "responses": [
        {
          "action": "audit_log"
        }
      ]
    },
    {
      "ruleId": "RULE_05",
      "severity": "HIGH",
      "responses": [
        {
          "action": "reject"
        }
      ]
    },
    {
      "ruleId": "RULE_06",
      "severity": "LOW",
      "responses": [
        {
          "action": "audit_log"
        }
      ]
    }
  ],
