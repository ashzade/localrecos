# Database
# For Neon: DATABASE_URL uses the pooler connection string, DATABASE_URL_UNPOOLED uses the direct connection
DATABASE_URL="postgresql://user:password@localhost:5432/localrecos"
DATABASE_URL_UNPOOLED="postgresql://user:password@localhost:5432/localrecos"

# Google Places API (New) - required for restaurant search
# Enable "Places API (New)" in Google Cloud Console, then create an API key
# Restrict the key to the Places API to limit billing exposure
GOOGLE_PLACES_API_KEY="your_google_places_api_key_here"

# OpenRouter API key — used for LLM-powered query parsing (Gemini Flash free tier)
# Sign up at https://openrouter.ai and copy your key here
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# Default city when geolocation fails (e.g. local dev where IP detection is skipped)
DEFAULT_CITY="Ottawa"
