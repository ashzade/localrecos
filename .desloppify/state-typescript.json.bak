    "review::.::holistic::mid_level_elegance::scrape_route_mutable_state_callback": {
      "id": "review::.::holistic::mid_level_elegance::scrape_route_mutable_state_callback",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "fetchWithFallback mutates caller-owned state via an advance() callback \u2014 a shared-mutable-state pattern across a function boundary",
      "detail": {
        "holistic": true,
        "dimension": "mid_level_elegance",
        "related_files": [
          "app/api/scrape/route.ts"
        ],
        "evidence": [
          "POST handler owns `let state: ScrapeState = 'PENDING'` and creates `const advance = (next: ScrapeState) => { assertValidTransition(state, next); state = next; }`",
          "fetchWithFallback receives advance as a parameter and calls it to mutate state owned by the outer scope",
          "After fetchWithFallback returns, the POST handler continues calling advance() to advance the same state variable \u2014 the state evolution is split between the inner function and the outer handler"
        ],
        "suggestion": "Return the final state from fetchWithFallback rather than passing a mutation callback. The outer handler can use the returned state to continue its own advance() calls. This makes the state ownership clear and removes shared-mutable-state coupling across the boundary.",
        "reasoning": "",
        "summary_hash": "e2f827f9"
      },
      "status": "fixed",
      "note": "not reported in latest holistic re-import",
