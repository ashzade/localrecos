    "review::.::holistic::high_level_elegance::scrape_is_triggered_both_server_side_in": {
      "id": "review::.::holistic::high_level_elegance::scrape_is_triggered_both_server_side_in",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "Scrape is triggered both server-side in api/search and client-side in SearchPoller, creating potential duplicate pipeline invocations",
      "detail": {
        "holistic": true,
        "dimension": "high_level_elegance",
        "related_files": [
          "app/api/search/route.ts",
          "components/SearchPoller.tsx"
        ],
        "evidence": [
          "app/api/search/route.ts (line 52-54) calls triggerScrape() fire-and-forget when result count is below 3. components/SearchPoller.tsx independently fires POST /api/scrape on mount for every search. Both can fire for the same city+query combination, resulting in duplicate Reddit scrapes and Google Places enrichment calls."
        ],
        "suggestion": "Establish a single scrape trigger point. Either the search API always triggers (and SearchPoller only polls for result updates), or SearchPoller is the sole trigger and the API never fires it. The current dual-trigger has no deduplication guard.",
