    "review::.::holistic::initialization_coupling::reddit_shared_mutable_token_cache": {
      "id": "review::.::holistic::initialization_coupling::reddit_shared_mutable_token_cache",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "lib/reddit.ts module-level `cachedToken` mutable singleton is shared across all concurrent Next.js requests in the same process with no synchronization",
      "detail": {
        "holistic": true,
        "dimension": "initialization_coupling",
        "related_files": [
          "lib/reddit.ts"
        ],
        "evidence": [
          "Line 58: `let cachedToken: { token: string; expiresAt: number } | null = null;` is module scope",
          "getAccessToken() reads and writes cachedToken without any lock \u2014 two concurrent requests can both see an expired token, both fetch new tokens, and the second write overwrites the first"
        ],
        "suggestion": "Replace the free variable with a lazily-initialized promise that is shared: `let tokenPromise: Promise<string | null> | null = null;`. Invalidate and recreate the promise only when expiry is detected. This avoids the race where concurrent requests both fetch tokens.",
        "reasoning": "",
        "summary_hash": "1b0c1703"
      },
      "status": "fixed",
