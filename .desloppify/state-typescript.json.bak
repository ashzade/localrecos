    "review::.::holistic::type_safety::validate_type_erasure": {
      "id": "review::.::holistic::type_safety::validate_type_erasure",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "All validators accept Record<string, unknown>, forcing double-cast through unknown at every call site",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "lib/validate.ts",
          "app/api/scrape/route.ts",
          "app/api/vote/route.ts",
          "app/api/restaurant-vote/route.ts",
          "lib/reddit.ts",
          "lib/google-places.ts",
          "lib/search.ts"
        ],
        "evidence": [
          "lib/validate.ts: validateParsedQuery(obj: Record<string, unknown>), validateRedditPost(obj: Record<string, unknown>), validatePlaceDetails(obj: Record<string, unknown>) \u2014 all validators erase the caller's type context.",
          "app/api/scrape/route.ts line 173: `validateRestaurantInput({...} as unknown as Record<string, unknown>)` \u2014 typed object cast away for validation.",
          "lib/reddit.ts line 141: `validateRedditPost(redditPost as unknown as Record<string, unknown>)` \u2014 same pattern.",
          "The ParsedQuery, RedditPost, PlaceDetails TypeScript interfaces exist in the codebase but are not used as the validator parameter types."
        ],
        "suggestion": "Update validator signatures to accept their corresponding typed interfaces: `validateParsedQuery(obj: ParsedQuery): void`, `validateRedditPost(obj: RedditPost): void`, etc. The internal field access can remain as `obj.field` since the interface guarantees the shape. This eliminates all double-casts and allows the type system to catch mismatches at validation call sites.",
        "reasoning": "",
        "summary_hash": "5f59c0af"
      },
      "status": "fixed",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-04-02T12:33:10+00:00",
      "last_seen": "2026-04-02T12:33:10+00:00",
      "resolved_at": "2026-04-02T13:03:23+00:00",
      "reopen_count": 0,
      "work_item_kind": "review_defect",
