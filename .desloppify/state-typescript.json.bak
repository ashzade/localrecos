    "review::.::holistic::error_consistency::validateredditpost_and_validateextracted": {
      "id": "review::.::holistic::error_consistency::validateredditpost_and_validateextracted",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "validateRedditPost and validateExtractedRestaurant throw ValidationError but callers silently catch and continue, undermining the validation contract",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "lib/reddit.ts",
          "lib/validate.ts"
        ],
        "evidence": [
          "lib/reddit.ts fetchSubredditPosts (lines 136-140) and scrapeRedditForRestaurants (lines 320-324) both catch ValidationError thrown by validators and log a console.warn, then continue. The validator is designed as a hard guard (throws on invalid data) but the catch silently degrades it to an optional filter. Any data that fails validation is silently dropped rather than surfacing the problem."
        ],
        "suggestion": "If the intent is to filter invalid items without halting, use a guard predicate instead of a throwing validator. If the intent is to enforce correctness, propagate the error. The current mixed pattern (throw + silent catch) is misleading.",
